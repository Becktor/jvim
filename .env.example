# Host UID/GID - auto-detected at runtime by bin/jvim
# Only set manually if running via docker compose directly:
# HOST_UID=1000
# HOST_GID=1000

# Nvim config repository (for build)
NVIM_CONFIG_REPO=https://github.com/Becktor/dev-env.git
NVIM_CONFIG_BRANCH=main

# Nvim config path on host (mounted at runtime for live editing)
NVIM_CONFIG_PATH=~/git/dotfiles/dev-env/nvim

# Workspace directory to mount
WORKSPACE=~/projects

# SSH directory (for git operations)
SSH_DIR=~/.ssh

# Git config file
GITCONFIG=~/.gitconfig
